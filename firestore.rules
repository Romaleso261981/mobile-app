rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isAuth() {
      return request.auth != null;
    }

    function userPath() {
      return /databases/$(database)/documents/users/$(request.auth.uid);
    }

    function userDocExists() {
      return isAuth() && exists(userPath());
    }

    function userData() {
      return get(userPath()).data;
    }

    function callerCompanyId() {
      return userData().companyId;
    }

    function callerIsAdmin() {
      return userDocExists() && userData().role == "admin";
    }

    function sameCompanyData(data) {
      return userDocExists() && data.companyId == callerCompanyId();
    }

    /** Реєстрація співробітника за кодом (поле joinCode у профілі). */
    function employeeJoinCreatesValidUser() {
      return request.resource.data.role == "employee" &&
        request.resource.data.companyId is string &&
        request.resource.data.joinCode is string &&
        exists(/databases/$(database)/documents/companyJoinCodes/$(request.resource.data.joinCode)) &&
        get(/databases/$(database)/documents/companyJoinCodes/$(request.resource.data.joinCode)).data.companyId
          == request.resource.data.companyId;
    }

    /** Адміністратор компанії після створення організації (у тому ж batch має з’явитися companies/{id}). */
    function adminCreatesOwnCompanyUser() {
      return request.resource.data.role == "admin" &&
        request.resource.data.companyId is string &&
        exists(/databases/$(database)/documents/companies/$(request.resource.data.companyId)) &&
        get(/databases/$(database)/documents/companies/$(request.resource.data.companyId)).data.createdByUid
          == request.auth.uid;
    }

    match /users/{userId} {
      allow read: if isAuth() && (
        request.auth.uid == userId ||
        (callerIsAdmin() && resource.data.companyId == callerCompanyId())
      );

      allow create: if isAuth() && request.auth.uid == userId && (
        employeeJoinCreatesValidUser() ||
        adminCreatesOwnCompanyUser()
      );

      allow update: if isAuth() && request.auth.uid == userId &&
        request.resource.data.role == resource.data.role &&
        request.resource.data.companyId == resource.data.companyId;

      allow delete: if false;
    }

    match /companies/{companyId} {
      allow read: if isAuth() && callerCompanyId() == companyId;
      allow create: if isAuth() && request.resource.data.createdByUid == request.auth.uid;
      allow update, delete: if false;
    }

    match /companyJoinCodes/{code} {
      allow get: if true;
      allow create: if isAuth() &&
        request.resource.data.companyId is string &&
        exists(/databases/$(database)/documents/companies/$(request.resource.data.companyId)) &&
        get(/databases/$(database)/documents/companies/$(request.resource.data.companyId)).data.createdByUid
          == request.auth.uid;
      allow update, delete: if false;
      allow list: if false;
    }

    match /categories/{categoryId} {
      allow read: if isAuth() && sameCompanyData(resource.data);
      allow create: if callerIsAdmin() &&
        request.resource.data.companyId == callerCompanyId() &&
        request.resource.data.createdBy == request.auth.uid;
      allow update, delete: if callerIsAdmin() && resource.data.companyId == callerCompanyId();
    }

    match /workEntries/{workId} {
      allow read: if isAuth() && sameCompanyData(resource.data) && (
        resource.data.userId == request.auth.uid ||
        callerIsAdmin()
      );

      allow create: if isAuth() &&
        request.resource.data.companyId == callerCompanyId() &&
        request.resource.data.userId == request.auth.uid;

      allow update, delete: if callerIsAdmin() && resource.data.companyId == callerCompanyId();
    }

    match /salaryPayouts/{payoutId} {
      allow read: if isAuth() && sameCompanyData(resource.data) && (
        resource.data.userId == request.auth.uid ||
        callerIsAdmin()
      );

      allow create: if isAuth() &&
        request.resource.data.companyId == callerCompanyId() &&
        (callerIsAdmin() || request.resource.data.userId == request.auth.uid);

      allow update, delete: if callerIsAdmin() && resource.data.companyId == callerCompanyId();
    }
  }
}
